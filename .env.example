# ============================================================
# Supabase — Get these from your Supabase project dashboard
# Settings > API > Project URL / anon public key
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ============================================================
# Resend — https://resend.com/api-keys
# ============================================================
RESEND_API_KEY=re_your_key_here

# The Gmail address that receives notifications
NOTIFICATION_EMAIL=your@gmail.com

# ============================================================
# Anthropic — https://console.anthropic.com/api-keys
# ============================================================
ANTHROPIC_API_KEY=sk-ant-your_key_here

# ============================================================
# Cal.com — Your public booking link
# e.g. https://cal.com/neo or https://cal.com/shivenpaudyal
# ============================================================
NEXT_PUBLIC_CALCOM_LINK=https://cal.com/your-username
